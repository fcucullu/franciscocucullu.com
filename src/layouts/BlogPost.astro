---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, tag, pubDate, subtitle, links, ogImage } = post.data;

const SITE_URL = 'https://franciscocucullu.com';
const postUrl = new URL(`/blog/${post.slug}`, SITE_URL).href;
const socialImage = new URL(ogImage ?? '/assets/og-image.jpg', SITE_URL).href;
const publishedISO = pubDate.toISOString();

// Related posts: up to 3 other published posts sharing the same tag.
// Related posts drive BOTH UX and crawl discovery. Same-tag-only + slice(3) left
// posts with rare tags nearly orphaned (Google never discovered them). Now every
// post links to 6 others: same-tag first, then a slug-rotated backfill so the
// inbound links spread evenly across ALL posts (no orphans, dense link graph).
const pool = (await getCollection('blog'))
	.filter((p) => !p.data.draft && p.slug !== post.slug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const sameTag = pool.filter((p) => p.data.tag === tag);
const rotateBy = [...post.slug].reduce((a, c) => a + c.charCodeAt(0), 0) % Math.max(pool.length, 1);
const ring = [...pool.slice(rotateBy), ...pool.slice(0, rotateBy)];
const related = [...new Map([...sameTag, ...ring].map((p) => [p.slug, p])).values()].slice(0, 6);

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	datePublished: publishedISO,
	image: socialImage,
	url: postUrl,
	author: {
		'@type': 'Person',
		name: 'Francisco Cucullu',
		url: SITE_URL,
	},
	publisher: {
		'@type': 'Person',
		name: 'Francisco Cucullu',
		url: SITE_URL,
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': postUrl,
	},
};
---

<BaseLayout
	title={`${title} | Francisco Cucullu`}
	description={description}
	image={ogImage}
	ogType="article"
	publishedTime={publishedISO}
	articleSection={tag}
	jsonLd={jsonLd}
>
	<article class="wrapper">
		<a href="/blog" class="back">&larr; Back</a>

		<header class="article-header">
			<span class="tag">{tag}</span>
			<h1>{title}</h1>
			{subtitle && <p class="subtitle">{subtitle}</p>}
			<p class="meta">By Francisco Cucullu &middot; AI Product Leader</p>
		</header>

		<div class="content">
			<Content />
		</div>

		{
			links && links.length > 0 && (
				<div class="article-links">
					{links.map((link) => (
						<a
							href={link.href}
							class="link-button"
							target={link.external ? '_blank' : undefined}
							rel={link.external ? 'noopener' : undefined}
						>
							{link.label}
						</a>
					))}
				</div>
			)
		}

		{
			related.length > 0 && (
				<section class="related">
					<h2>Related posts</h2>
					<div class="related-grid">
						{related.map((rel) => (
							<a href={`/blog/${rel.slug}`} class="related-card">
								<span class="related-tag">{rel.data.tag}</span>
								<h3>{rel.data.title}</h3>
								<p>{rel.data.description}</p>
							</a>
						))}
					</div>
				</section>
			)
		}

		<footer class="article-footer">
			<p>
				Francisco Cucullu is an AI Product Leader building AI products at scale. Follow along on{' '}
				<a href="https://www.linkedin.com/in/franciscocucullu/">LinkedIn</a> and{' '}
				<a href="https://x.com/fcucullu">X</a>, or <a href="/">learn more</a>.
			</p>
		</footer>
	</article>
</BaseLayout>

<style>
	.wrapper {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	.back {
		color: #a855f7;
		text-decoration: none;
		font-size: var(--text-sm);
		display: inline-block;
		margin-bottom: 2rem;
	}

	.article-header {
		margin-bottom: 3rem;
	}

	.tag {
		font-size: 0.75rem;
		padding: 0.25rem 0.75rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		display: inline-block;
		margin-bottom: 1rem;
	}

	h1 {
		font-size: var(--text-3xl);
		color: var(--gray-0);
		margin-bottom: 0.75rem;
		line-height: 1.2;
	}

	.subtitle {
		font-size: var(--text-lg);
		color: var(--gray-300);
		margin-bottom: 0.5rem;
	}

	.meta {
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	.content {
		color: var(--gray-200);
		line-height: 1.8;
		font-size: var(--text-md);
	}

	.content :global(h2) {
		font-size: var(--text-2xl);
		color: var(--gray-0);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}

	.content :global(h3) {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}

	.content :global(p) {
		margin-bottom: 1.25rem;
	}

	.content :global(ul),
	.content :global(ol) {
		padding-left: 1.5rem;
		margin-bottom: 1.25rem;
	}

	.content :global(li) {
		margin-bottom: 0.5rem;
	}

	.content :global(blockquote) {
		border-left: 3px solid var(--accent-regular);
		padding-left: 1.25rem;
		margin: 1.5rem 0;
		font-style: italic;
		color: var(--gray-300);
	}

	.content :global(hr) {
		border: none;
		border-top: 1px solid var(--gray-800);
		margin: 2rem 0;
	}

	.content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.5rem 0;
		font-size: var(--text-sm);
	}

	.content :global(th) {
		text-align: left;
		padding: 0.75rem;
		background: var(--gray-999_40);
		color: var(--gray-0);
		border-bottom: 1px solid var(--gray-800);
	}

	.content :global(td) {
		padding: 0.75rem;
		border-bottom: 1px solid var(--gray-800);
		color: var(--gray-300);
	}

	.content :global(a) {
		color: #a855f7;
	}

	.content :global(.metrics-grid) {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.5rem 0;
	}

	.content :global(.metric-card) {
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.25rem;
		text-align: center;
	}

	.content :global(.metric-value) {
		display: block;
		font-size: 2rem;
		font-weight: 800;
		color: #a855f7;
		line-height: 1;
		margin-bottom: 0.5rem;
	}

	.content :global(.metric-label) {
		font-size: 0.8rem;
		color: var(--gray-400);
	}

	.content :global(.video-wrapper) {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
		overflow: hidden;
		border-radius: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.content :global(.video-wrapper iframe) {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	.content :global(.photo-grid) {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin: 1.5rem 0;
	}

	.content :global(.photo-grid img) {
		width: 100%;
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
		object-fit: cover;
		aspect-ratio: 16 / 10;
	}

	.article-links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.link-button {
		display: inline-block;
		padding: 0.6rem 1.25rem;
		border-radius: 0.5rem;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		text-decoration: none;
		font-weight: 600;
		font-size: var(--text-sm);
		transition: opacity 0.2s;
	}

	.link-button:hover {
		opacity: 0.85;
	}

	.related {
		margin-top: 3rem;
	}

	.related h2 {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin-bottom: 1.25rem;
	}

	.related-grid {
		display: grid;
		gap: 1rem;
	}

	.related-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.25rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		text-decoration: none;
		color: var(--gray-200);
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.related-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.related-tag {
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		white-space: nowrap;
		align-self: flex-start;
	}

	.related-card h3 {
		font-size: var(--text-md);
		color: var(--gray-0);
		margin: 0;
	}

	.related-card p {
		font-size: var(--text-sm);
		color: var(--gray-300);
		margin: 0;
		line-height: 1.6;
	}

	.article-footer {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--gray-800);
		color: var(--gray-400);
		font-size: var(--text-sm);
	}

	.article-footer a {
		color: #a855f7;
	}

	@media (min-width: 50em) {
		h1 {
			font-size: var(--text-4xl);
		}

		.content :global(.metrics-grid) {
			grid-template-columns: repeat(4, 1fr);
		}

		.related-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
