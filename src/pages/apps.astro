---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';

const apps = (await getCollection('apps')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Apps | Francisco Cucullu"
	description="Live apps built by Francisco Cucullu — a control tower for all my projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Apps I Build"
				tagline="Side projects shipped from scratch. Designed, coded, and maintained solo."
				align="center"
			/>
			<div class="apps-grid">
				{apps.map((app) => (
					<div class="app-card" data-fast-goal={`click_app_${app.slug}`}>
						<img src={app.data.img} alt={app.data.img_alt || ''} loading="lazy" class="app-icon" />
						<div class="app-info">
							<div class="app-header">
								<h3>{app.data.title}</h3>
								<span class:list={['status', app.data.status]}>{app.data.status}</span>
							</div>
							<p class="app-desc">{app.data.description}</p>
						</div>
						<div class="app-links">
							{app.data.playStoreUrl && (
								<a href={app.data.playStoreUrl} target="_blank" rel="noopener" class="store-badge">
									<img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" />
								</a>
							)}
							{app.data.appStoreUrl && (
								<a href={app.data.appStoreUrl} target="_blank" rel="noopener" class="store-badge">
									<img src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg" alt="Download on the App Store" />
								</a>
							)}
							<a href={app.data.url} target="_blank" rel="noopener" class="web-link">
								Open Web App →
							</a>
						</div>
					</div>
				))}
			</div>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<script>
	window?.datafast?.("surfed-to-apps");
</script>

<style>
	.apps-grid {
		display: grid;
		gap: 1.5rem;
		list-style: none;
		padding: 0;
	}

	.app-card {
		display: grid;
		grid-template-columns: 64px 1fr auto;
		gap: 1rem;
		padding: 1.25rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		color: var(--gray-200);
		transition: box-shadow var(--theme-transition), transform 0.2s;
		align-items: center;
	}

	.app-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.app-icon {
		width: 64px;
		height: 64px;
		object-fit: cover;
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
	}

	.app-info {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}

	.app-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.app-header h3 {
		font-size: var(--text-lg);
		margin: 0;
		color: var(--gray-0);
	}

	.status {
		font-size: var(--text-xs, 0.75rem);
		padding: 0.15rem 0.5rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		flex-shrink: 0;
	}

	.status.live {
		background: rgba(34, 197, 94, 0.15);
		color: #22c55e;
	}

	.status.beta {
		background: rgba(234, 179, 8, 0.15);
		color: #eab308;
	}

	.status.offline {
		background: rgba(239, 68, 68, 0.15);
		color: #ef4444;
	}

	.app-desc {
		font-size: var(--text-sm);
		color: var(--gray-300);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.app-links {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.store-badge {
		display: block;
	}

	.store-badge img {
		height: 40px;
		width: auto;
	}

	.web-link {
		font-size: var(--text-sm, 0.875rem);
		color: #fff;
		background: var(--accent-regular);
		text-decoration: none;
		white-space: nowrap;
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		font-weight: 600;
		transition: background 0.2s;
	}

	.web-link:hover {
		background: var(--accent-dark);
	}

	/* Mobile: stack vertically */
	@media (max-width: 49.99em) {
		.app-card {
			grid-template-columns: 56px 1fr;
			grid-template-rows: auto auto;
		}

		.app-icon {
			width: 56px;
			height: 56px;
			grid-row: 1;
		}

		.app-info {
			grid-row: 1;
		}

		.app-links {
			grid-column: 1 / -1;
			grid-row: 2;
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.75rem;
		}
	}

	/* Desktop: 3 columns */
	@media (min-width: 50em) {
		.apps-grid {
			gap: 1.25rem;
		}

		.app-card {
			grid-template-columns: 80px 1fr auto;
			gap: 1.25rem;
			padding: 1.5rem;
		}

		.app-icon {
			width: 80px;
			height: 80px;
		}

		.app-desc {
			-webkit-line-clamp: 3;
		}
	}
</style>
