---
import BaseLayout from '../layouts/BaseLayout.astro';
import CallToAction from '../components/CallToAction.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';

const channels = [
	{
		label: 'Email',
		value: 'francisco.cucullu@gmail.com',
		href: 'mailto:francisco.cucullu@gmail.com',
		icon: 'mail-outline',
		goal: 'click_on_contact_mail',
	},
	{
		label: 'LinkedIn',
		value: 'in/franciscocucullu',
		href: 'https://linkedin.com/in/franciscocucullu',
		icon: 'linkedin-logo',
		goal: 'click_on_contact_linkedin',
	},
	{
		label: 'X',
		value: '@fcucullu',
		href: 'https://x.com/fcucullu',
		icon: 'x-logo',
		goal: 'click_on_contact_x',
	},
	{
		label: 'GitHub',
		value: 'fcucullu',
		href: 'https://github.com/fcucullu',
		icon: 'github-logo',
		goal: 'click_on_contact_github',
	},
];
---

<BaseLayout title="Contact | Francisco Cucullu" description="Get in touch with Francisco Cucullu — open to senior AI product roles (remote) and B2B consultancy, worldwide.">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Let's talk"
				tagline="Open to senior AI product roles (remote) and B2B consultancy, worldwide. The fastest way to reach me is email — I read every message."
				align="start"
			/>

			<div class="cta">
				<CallToAction href="mailto:francisco.cucullu@gmail.com" data-fast-goal="click_on_contact_cta">
					Email me
					<Icon icon="paper-plane-tilt" size="1.1em" />
				</CallToAction>
			</div>

			<ul class="channels">
				{
					channels.map(({ label, value, href, icon, goal }) => (
						<li>
							<a href={href} data-fast-goal={goal}>
								<Icon icon={icon} color="var(--accent-regular)" size="1.6em" gradient />
								<span class="channel-text">
									<span class="channel-label">{label}</span>
									<span class="channel-value">{value}</span>
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
	</div>
</BaseLayout>

<style>
	.cta {
		display: flex;
		justify-content: flex-start;
	}

	.channels {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.channels a {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
		border-radius: 0.75rem;
		background-color: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		color: var(--gray-200);
		transition:
			color var(--theme-transition),
			background-color var(--theme-transition);
	}

	.channels a:hover,
	.channels a:focus {
		color: var(--gray-0);
		background-color: var(--accent-subtle-overlay);
	}

	.channel-text {
		display: flex;
		flex-direction: column;
		line-height: 1.3;
	}

	.channel-label {
		font-family: var(--font-brand);
		font-weight: 600;
		color: var(--gray-0);
	}

	.channel-value {
		font-size: var(--text-sm);
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		.channels {
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}
	}
</style>
