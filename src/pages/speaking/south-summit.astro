---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="South Summit | Francisco Cucullu" description="Pitch at South Summit, Europe's leading startup conference">
<div class="wrapper">
<a href="/" class="back">← Back</a>
<h1>South Summit</h1>
<p class="meta">One of the leading startup conferences in Europe</p>
<p>Pitched on the main stage at South Summit and was interviewed by media on-site.</p>
<div class="video-wrapper"><iframe src="https://www.youtube.com/embed/i2spr2QhaGM" title="South Summit Pitch" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="photos"><img src="/assets/speaking-1779160559702-AQADXgxrG04GYER-.jpg" alt="Francisco on South Summit stage" /><img src="/assets/speaking-1779160537307-AQADXQxrG04GYER-.jpg" alt="Francisco interviewed at South Summit" /></div>
</div>
</BaseLayout>
<style>
.wrapper{max-width:800px;margin:0 auto;padding:2rem 1.5rem 4rem}.back{color:var(--accent-light);text-decoration:none;font-size:var(--text-sm);display:inline-block;margin-bottom:2rem}h1{font-size:var(--text-4xl);color:var(--gray-0);margin-bottom:.5rem}.meta{color:var(--gray-400);font-size:var(--text-sm);margin-bottom:.5rem}p{color:var(--gray-300);line-height:1.6;margin-bottom:1rem}.video-wrapper{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:.75rem;margin-bottom:1.5rem}.video-wrapper iframe{position:absolute;top:0;left:0;width:100%;height:100%}.photos{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}.photos img{width:100%;border-radius:.75rem;border:1px solid var(--gray-800);object-fit:cover;aspect-ratio:16/10}
</style>
