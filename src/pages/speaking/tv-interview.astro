---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="TV Interview | Francisco Cucullu" description="Television interview on Hola Andalucia">
<div class="wrapper">
<a href="/" class="back">← Back</a>
<h1>Television Interview</h1>
<p class="meta">Hola Andalucia, 101 TV, Malaga</p>
<p>Featured on the "Malaga Tech" segment discussing entrepreneurship and technology innovation.</p>
<div class="video-wrapper"><iframe src="https://www.youtube.com/embed/hDBkySJCi0Q" title="TV Interview" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="photos"><img src="/assets/speaking-1779160516834-AQADXAxrG04GYER-.jpg" alt="Francisco on TV" /><img src="/assets/speaking-1779160564803-AQADXwxrG04GYER-.jpg" alt="Francisco on TV" /></div>
</div>
</BaseLayout>
<style>
.wrapper{max-width:800px;margin:0 auto;padding:2rem 1.5rem 4rem}.back{color:var(--accent-light);text-decoration:none;font-size:var(--text-sm);display:inline-block;margin-bottom:2rem}h1{font-size:var(--text-4xl);color:var(--gray-0);margin-bottom:.5rem}.meta{color:var(--gray-400);font-size:var(--text-sm);margin-bottom:.5rem}p{color:var(--gray-300);line-height:1.6;margin-bottom:1rem}.video-wrapper{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:.75rem;margin-bottom:1.5rem}.video-wrapper iframe{position:absolute;top:0;left:0;width:100%;height:100%}.photos{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}.photos img{width:100%;border-radius:.75rem;border:1px solid var(--gray-800);object-fit:cover;aspect-ratio:16/10}
</style>
