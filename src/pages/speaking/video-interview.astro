---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Video Interview | Francisco Cucullu" description="In-depth interview on product vision and strategy">
<div class="wrapper">
<a href="/" class="back">← Back</a>
<h1>Video Interview</h1>
<p>In-depth interview on product vision, market strategy, and startup execution.</p>
<div class="video-wrapper"><iframe src="https://www.youtube.com/embed/VAnII-62ry4" title="Video Interview" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
</div>
</BaseLayout>
<style>
.wrapper{max-width:800px;margin:0 auto;padding:2rem 1.5rem 4rem}.back{color:var(--accent-light);text-decoration:none;font-size:var(--text-sm);display:inline-block;margin-bottom:2rem}h1{font-size:var(--text-4xl);color:var(--gray-0);margin-bottom:.5rem}p{color:var(--gray-300);line-height:1.6;margin-bottom:1rem}.video-wrapper{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:.75rem;margin-bottom:1.5rem}.video-wrapper iframe{position:absolute;top:0;left:0;width:100%;height:100%}
</style>
