---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hi! I'm Francisco"
					align="start"
					tagline={`AI Product Leader.<br><br>I build AI products at scale: multi-modal quality systems analyzing millions of daily interactions, algorithmic trading with 400%+ returns. Dual MSc in Quantitative Finance.`}
					>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> AI/ML</Pill>
						<Pill><Icon icon="strategy" size="1.33em" /> Product</Pill>
						<Pill><Icon icon="trophy" size="1.33em" /> Leadership</Pill>
					</div>
				</Hero>

				<img
					alt="Francisco Cucullu smiling in a black shirt with a 'love' inspiring inscription"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>AI Experience</h3>
					<p>Building AI products in production, from enterprise scale to social impact.</p>
				</header>

				<div class="ai-cards">
					<div class="ai-card">
						<div class="ai-card-header">
							<span class="ai-tag">Current</span>
							<h4>RAID (Rapid AI Development)</h4>
						</div>
						<p>Leading the full AI product cycle from ideation to MVP in one week. Building and shipping AI-powered products at startup speed inside a global enterprise. Leading a cross-functional team of engineers and designers.</p>
						<div class="ai-tags">
							<span class="ai-pill">Rapid Prototyping</span>
							<span class="ai-pill">Product Strategy</span>
							<span class="ai-pill">LLMs</span>
							<span class="ai-pill">MVP</span>
						</div>
					</div>
					<div class="ai-card">
						<div class="ai-card-header">
							<span class="ai-tag">Enterprise AI</span>
							<h4>AI Quality Assurance Suite</h4>
						</div>
						<p>Multi-modal AI system for a global CX leader (130K+ employees). Analyzing millions of daily customer interactions using audio processing, speech-to-text, and LLM-based transcript analysis. Driving multi-million dollar annual savings.</p>
						<div class="ai-tags">
							<span class="ai-pill">Multi-modal AI</span>
							<span class="ai-pill">LLMs</span>
							<span class="ai-pill">Speech-to-Text</span>
							<span class="ai-pill">NLP</span>
							<span class="ai-pill">Python</span>
						</div>
					</div>
					<div class="ai-card">
						<div class="ai-card-header">
							<span class="ai-tag">Fintech / AI</span>
							<h4>Xcapit: AI-Powered Wealth Management</h4>
						</div>
						<p>Algorithmic trading managing a $2M portfolio with 400%+ annual returns. AI-driven portfolio management services. Pivoted to financial inclusion: $650K in microloans to 330 underbanked individuals. Funded by UNICEF and Ethereum Foundation. Recognized as a Digital Public Good.</p>
						<div class="ai-tags">
							<span class="ai-pill">Algorithmic Trading</span>
							<span class="ai-pill">ML</span>
							<span class="ai-pill">Blockchain</span>
							<span class="ai-pill">UNICEF</span>
							<span class="ai-pill">Python</span>
						</div>
					</div>
				</div>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>I Ship Fast</h3>
					<p>
						Apps built solo, from idea to production in days. Native Android apps on Google Play, PWAs, SaaS platforms.
						<br /><a href="/apps" class="accent-link">See all apps →</a>
					</p>
				</header>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Code & Open Source</h3>
					<p>I write code, not just specs. Here's what I've built and open-sourced.</p>
				</header>

				<div class="ai-cards">
					<a href="https://github.com/fcucullu/api-contract-hub" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Full-Stack</span>
							<h4>API Contract Hub</h4>
						</div>
						<p>Collaborative API contract platform that auto-generates test cases from schemas: structural, type-mismatch, and format validation tests. Prevents integration bugs before they ship.</p>
						<div class="ai-tags">
							<span class="ai-pill">TypeScript</span>
							<span class="ai-pill">Next.js</span>
							<span class="ai-pill">Prisma</span>
							<span class="ai-pill">Test Generation</span>
						</div>
					</a>
					<a href="https://github.com/fcucullu/orbio-onboarding" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">AI Agent</span>
							<h4>AI Onboarding Agent</h4>
						</div>
						<p>AI-native HR onboarding platform. New hires complete onboarding via a Claude-powered conversational agent. HR dashboard tracks pipeline, progress, and at-risk hires in real-time.</p>
						<div class="ai-tags">
							<span class="ai-pill">Claude API</span>
							<span class="ai-pill">Python</span>
							<span class="ai-pill">FastAPI</span>
							<span class="ai-pill">React</span>
						</div>
					</a>
					<a href="https://github.com/fcucullu/trading-fx" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Algorithmic</span>
							<h4>FX Arbitrage Engine</h4>
						</div>
						<p>Automated trading system that exploited FX pricing inefficiencies in the Argentine market. Multi-threaded execution, real-time price monitoring, WebSocket feeds. Led to trading desk leadership.</p>
						<div class="ai-tags">
							<span class="ai-pill">Python</span>
							<span class="ai-pill">WebSockets</span>
							<span class="ai-pill">Multi-threading</span>
							<span class="ai-pill">Real-time</span>
						</div>
					</a>
				</div>

				<div class="github-cta">
					<a href="https://github.com/fcucullu" target="_blank" rel="noopener" class="accent-link">
						View all 30+ repos on GitHub →
					</a>
				</div>
			</section>

			<section class="section with-background with-cta">
				<header data-fast-scroll="scroll_to_projects_head" class="section-header stack gap-2 lg:gap-4">
					<h3>Selected Work</h3>
					<p>Projects built for clients and companies across fintech, AI, and enterprise.</p>
				</header>

				<div data-fast-scroll="scroll_to_projects" class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction data-fast-goal="click_on_view_all_projects" href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section data-fast-scroll="scroll_to_recommendations" class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Recommendations</h3>
					<p>
						I have been fortunate enough to receive praise for my work on several occasions. Take
						a look at <a data-fast-goal="click_on_recommendations" href="https://www.linkedin.com/in/franciscocucullu/details/recommendations" class="inline-link">my 20+ recommendations on LinkedIn</a>.
					</p>
				</header>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<script>
	window?.datafast?.("surfed-to-apps");
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.ai-cards {
		display: grid;
		gap: 1.25rem;
		grid-column: 1 / -1;
	}

	.ai-card {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		padding: 1.5rem;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.ai-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.ai-card-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.ai-card h4 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin: 0;
	}

	.ai-card p {
		color: var(--gray-300);
		font-size: var(--text-sm);
		line-height: 1.6;
		margin: 0;
	}

	.ai-tag {
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		white-space: nowrap;
	}

	.ai-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.75rem;
	}

	.ai-pill {
		font-size: 0.65rem;
		padding: 0.2rem 0.55rem;
		border-radius: 999rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		white-space: nowrap;
	}

	.repo-card {
		text-decoration: none;
		color: inherit;
		cursor: pointer;
	}

	.github-cta {
		grid-column: 1 / -1;
		text-align: center;
		margin-top: 0.5rem;
	}

	.accent-link,
	.inline-link {
		color: var(--accent-light);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.2em;
		transition: color 0.2s;
	}

	.accent-link:hover,
	.inline-link:hover {
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.ai-cards {
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5rem;
		}

		.ai-card h4 {
			font-size: var(--text-lg);
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			height: 9.5rem;
		}
	}
</style>
