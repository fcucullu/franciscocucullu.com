---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import CallToAction from '../components/CallToAction.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';

const latestEssays = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3)
	.map((post) => ({
		title: post.data.title,
		description: post.data.description,
		href: `/blog/${post.slug}`,
		tag: post.data.tag,
		external: false,
	}));

const apps = (await getCollection('apps'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hi! I'm Francisco"
					align="start"
					tagline={`AI Product Leader who codes. I take products from 0&#8594;1 to enterprise scale.<br><br>Across my career I have led engineering teams (up to 4 squads, 24 engineers), driven multi-million dollar savings with AI in production, raised engineering velocity 137% at a fintech, and founded and sold products. Earlier, a quant background and algorithmic trading. Dual MSc in Quantitative Finance.`}
					>
					<div class="roles">
						<Pill><Icon icon="strategy" size="1.33em" /> AI Products</Pill>
						<Pill><Icon icon="code" size="1.33em" /> 0&#8594;1 to Enterprise Scale</Pill>
						<Pill><Icon icon="leadership" size="1.33em" /> People Leader</Pill>
					</div>
					<p class="availability">Open to senior AI product roles (remote) and B2B consultancy, worldwide.</p>
					<div class="hero-cta">
						<CallToAction href="mailto:francisco.cucullu@gmail.com" data-fast-goal="click_on_hero_cta">
							Let's talk
							<Icon icon="paper-plane-tilt" size="1.1em" />
						</CallToAction>
					</div>
				</Hero>

				<img
					alt="Francisco Cucullu smiling in a black shirt with a 'love' inspiring inscription"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header data-fast-scroll="scroll_to_projects_head" class="section-header stack gap-2 lg:gap-4">
					<h3>Selected Work &amp; Frameworks</h3>
					<p>Business and product cases across enterprise AI, fintech, and 0&#8594;1 startups.</p>
				</header>

				<div data-fast-scroll="scroll_to_projects" class="ai-cards">
					<a href="/work/quantitative-finance-for-blockchain" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">UNICEF-Backed Fintech</span>
							<h4>Xcapit: UNICEF-Backed AI Fintech</h4>
						</div>
						<p>AI-driven wealth management built with a team of 5 PhDs, then pivoted to financial inclusion: $650K in microloans to 330 underbanked individuals. Funded by UNICEF and the Ethereum Foundation, recognized as a Digital Public Good.</p>
						<div class="ai-tags">
							<span class="ai-pill">AI/ML</span>
							<span class="ai-pill">Blockchain</span>
							<span class="ai-pill">UNICEF</span>
							<span class="ai-pill">Financial Inclusion</span>
						</div>
					</a>
					<a href="/work/ai-quality-assurance" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Enterprise AI</span>
							<h4>AI Quality Assurance at Scale</h4>
						</div>
						<p>Led a flagship multi-modal AI suite (audio, speech-to-text, LLMs) for a global CX leader (170K+ employees), driving multi-million dollar savings and a 50% efficiency gain. Architected to scale to 9M+ daily interactions and 20K+ users, live today across 51 client accounts.</p>
						<div class="ai-tags">
							<span class="ai-pill">Multi-modal AI</span>
							<span class="ai-pill">LLMs</span>
							<span class="ai-pill">Speech-to-Text</span>
							<span class="ai-pill">NLP</span>
							<span class="ai-pill">Python</span>
						</div>
					</a>
					<a href="/work/timed-integrations" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Acquisition</span>
							<h4>Timed Integrations: Sold to Factorial</h4>
						</div>
						<p>Built a micro-SaaS integrating Italian ERPs with Factorial's HR platform, automating time-tracking data ingestion. Sold the product to Factorial.</p>
						<div class="ai-tags">
							<span class="ai-pill">Micro-SaaS</span>
							<span class="ai-pill">ERP Integration</span>
							<span class="ai-pill">HR Tech</span>
							<span class="ai-pill">Acquisition</span>
						</div>
					</a>
					<a href="/work/hastee" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Product Leadership</span>
							<h4>Hastee: 137% Engineering Velocity</h4>
						</div>
						<p>Tech Product Manager at an HR fintech. Redesigned delivery processes to increase engineering output by 137%, leading 13 engineers across 3 teams and aligning the roadmap with C-level objectives.</p>
						<div class="ai-tags">
							<span class="ai-pill">Product Management</span>
							<span class="ai-pill">HR/Fintech</span>
							<span class="ai-pill">Engineering Velocity</span>
							<span class="ai-pill">Agile</span>
						</div>
					</a>
					<a href="/work/ai-onboarding-agent" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">AI Agent</span>
							<h4>AI Onboarding Agent</h4>
						</div>
						<p>AI-native HR onboarding platform. New hires complete onboarding through a Claude-powered conversational agent, while an HR dashboard tracks pipeline, progress, and at-risk hires in real time.</p>
						<div class="ai-tags">
							<span class="ai-pill">Claude API</span>
							<span class="ai-pill">Python</span>
							<span class="ai-pill">FastAPI</span>
							<span class="ai-pill">React</span>
						</div>
					</a>
					<a href="/blog/wasp-framework" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Framework</span>
							<h4>WASP (Weekly AI Sprint Protocol)</h4>
						</div>
						<p>A hypothesis-driven methodology I developed to take an AI product from challenge to a validated MVP in five business days. Building and shipping AI products at startup speed inside a global enterprise.</p>
						<div class="ai-tags">
							<span class="ai-pill">Rapid Prototyping</span>
							<span class="ai-pill">Product Strategy</span>
							<span class="ai-pill">LLMs</span>
							<span class="ai-pill">MVP</span>
						</div>
					</a>
				</div>

				<div class="cta">
					<CallToAction data-fast-goal="click_on_view_all_projects" href="/portfolio#work">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section data-fast-scroll="scroll_to_recommendations" class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>What People Say</h3>
					<p>
						20+ recommendations on <a data-fast-goal="click_on_recommendations" href="https://www.linkedin.com/in/franciscocucullu/details/recommendations" class="inline-link">LinkedIn</a>.
					</p>
				</header>

				<div class="testimonials">
					<div class="testimonial">
						<p class="quote">"Francisco approaches every challenge with proactivity and a constant drive to grow. His sharp critical thinking helps uncover smart, well-grounded solutions. He doesn't just adjust to change, he uses it as a tool for transformation."</p>
						<p class="author"><strong>Leonardo Fister</strong> · Sr. Product & BI Manager, Supercanal</p>
					</div>
					<div class="testimonial">
						<p class="quote">"He quickly assumed the responsibilities of the Product Team and swiftly understood our needs. He is highly professional and possesses extensive knowledge of processes, product management, and priority setting."</p>
						<p class="author"><strong>Martin Bettaglio</strong> · BI Consultant, Hastee</p>
					</div>
					<div class="testimonial">
						<p class="quote">"Francisco possesses a remarkable ability to streamline processes seamlessly. His commitment to client satisfaction is exceptional. He brings out the best in the team, ensuring optimal outcomes while maintaining a strong client-centric approach."</p>
						<p class="author"><strong>Muhammad Shaheen</strong> · Senior QA Consultant, Aster DM Healthcare</p>
					</div>
					<div class="testimonial">
						<p class="quote">"Without a doubt, I would highlight his proactivity and resilience. He knows how to maximize everyone's capabilities. As a person, he is also a 10, honest and transparent."</p>
						<p class="author"><strong>Daniel Rodrigo</strong> · Senior Engineer, Nordex Group</p>
					</div>
					<div class="testimonial">
						<p class="quote">"Ha demostrado ser una persona muy proactiva, con gran iniciativa, mucha tenacidad y con gran adaptabilidad a los cambios. Tiene muy buenas habilidades de comunicacion y liderazgo."</p>
						<p class="author"><strong>Jackson Echeverri</strong> · CTO & Cofounder, Lesiga</p>
					</div>
					<div class="testimonial">
						<p class="quote">"Francisco es lo que se denomina un intraemprendor. Fue haciendose lugar como desarrollador utilizando Python para realizar algoritmos de trading, creando un nuevo area dentro de la empresa."</p>
						<p class="author"><strong>Tobias Girado</strong> · Software Engineer, Chevron</p>
					</div>
				</div>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Latest Essays</h3>
					<p>Writing on AI product strategy, engineering judgment, and building at scale.</p>
				</header>

				<div class="ai-cards">
					{latestEssays.map((essay) => (
						<a href={essay.href} target={essay.external ? "_blank" : undefined} rel={essay.external ? "noopener" : undefined} class="ai-card repo-card">
							<div class="ai-card-header">
								<span class="ai-tag">{essay.tag}</span>
							</div>
							<h4>{essay.title}</h4>
							<p>{essay.description}</p>
						</a>
					))}
				</div>

				<div class="github-cta">
					<a href="/blog" class="accent-link">Read all essays →</a>
				</div>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Speaking & Media</h3>
					<p>Pitching, presenting, and representing products on stage and on screen.</p>
				</header>

				<div class="ai-cards">
					<a href="/blog/speaking-tv-interview" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">TV</span>
							<h4>Television Interview</h4>
						</div>
						<p>Featured on "Malaga Tech" segment discussing entrepreneurship and technology innovation.</p>
					</a>
					<a href="/blog/speaking-warsaw" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Pitch</span>
							<h4>Warsaw Startup Stage</h4>
						</div>
						<p>Startup pitch at an international competition in Warsaw, Poland.</p>
					</a>
					<a href="/blog/speaking-south-summit" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Pitch</span>
							<h4>South Summit</h4>
						</div>
						<p>Pitched on the main stage at South Summit, one of the leading startup conferences in Europe.</p>
					</a>
					<a href="/blog/speaking-des-malaga" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Pitch</span>
							<h4>DES Malaga</h4>
						</div>
						<p>Pitched FlexRent to investors at the Digital Enterprise Show, one of Europe's largest digital transformation events.</p>
					</a>
					<a href="/blog/speaking-coach-summit" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Summit</span>
							<h4>Coach Summit</h4>
						</div>
						<p>Presented AI AutoQA at enterprise Coach Summits in Barcelona and Seville. 80+ attendees.</p>
					</a>
					<a href="/blog/speaking-video-interview" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Interview</span>
							<h4>Video Interview</h4>
						</div>
						<p>In-depth interview on product vision, market strategy, and startup execution.</p>
					</a>
					<a href="/blog/speaking-radio-interview" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Radio</span>
							<h4>Radio Interview</h4>
						</div>
						<p>Radio interview on technology, entrepreneurship, and innovation.</p>
					</a>
					<a href="https://www.linkedin.com/pulse/dealing-heterocedaticity-francisco-cucullu" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Article</span>
							<h4>Dealing with Heteroscedasticity</h4>
						</div>
						<p>Technical article on statistical modeling and handling non-constant variance in financial data.</p>
					</a>
				</div>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Product Builder & Entrepreneur</h3>
					<p>
						I build products end to end to solve real problems, from idea to users. Native apps, PWAs, and SaaS platforms.
						<br /><a href="/portfolio#apps" class="accent-link">See all apps →</a>
					</p>
				</header>

				<div class="app-carousel-wrapper">
					<div class="app-carousel">
						{[...apps, ...apps].map((app, i) => (
							<a href={app.data.playStoreUrl || app.data.url} target="_blank" rel="noopener" class="app-carousel-item" key={`${app.slug}-${i}`}>
								<img src={app.data.img} alt={app.data.title} />
								<span>{app.data.title}</span>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Code & Open Source</h3>
					<p>I write code, not just specs. Here's what I've built and open-sourced.</p>
				</header>

				<div class="ai-cards">
					<a href="https://github.com/fcucullu/api-contract-hub" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Full-Stack</span>
							<h4>API Contract Hub</h4>
						</div>
						<p>Collaborative API contract platform that auto-generates test cases from schemas: structural, type-mismatch, and format validation tests. Prevents integration bugs before they ship.</p>
						<div class="ai-tags">
							<span class="ai-pill">TypeScript</span>
							<span class="ai-pill">Next.js</span>
							<span class="ai-pill">Prisma</span>
							<span class="ai-pill">Test Generation</span>
						</div>
					</a>
					<a href="https://github.com/fcucullu/orbio-onboarding" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">AI Agent</span>
							<h4>AI Onboarding Agent</h4>
						</div>
						<p>AI-native HR onboarding platform. New hires complete onboarding via a Claude-powered conversational agent. HR dashboard tracks pipeline, progress, and at-risk hires in real-time.</p>
						<div class="ai-tags">
							<span class="ai-pill">Claude API</span>
							<span class="ai-pill">Python</span>
							<span class="ai-pill">FastAPI</span>
							<span class="ai-pill">React</span>
						</div>
					</a>
					<a href="https://github.com/fcucullu/trading-fx" target="_blank" rel="noopener" class="ai-card repo-card">
						<div class="ai-card-header">
							<span class="ai-tag">Algorithmic</span>
							<h4>FX Arbitrage Engine</h4>
						</div>
						<p>Automated trading system that exploited FX pricing inefficiencies in the Argentine market. Multi-threaded execution, real-time price monitoring, WebSocket feeds. Led to trading desk leadership.</p>
						<div class="ai-tags">
							<span class="ai-pill">Python</span>
							<span class="ai-pill">WebSockets</span>
							<span class="ai-pill">Multi-threading</span>
							<span class="ai-pill">Real-time</span>
						</div>
					</a>
				</div>

				<div class="github-cta">
					<a href="https://github.com/fcucullu" target="_blank" rel="noopener" class="accent-link">
						View all 30+ repos on GitHub →
					</a>
				</div>
			</section>

		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<script>
	window?.datafast?.("surfed-to-apps");
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.availability {
		font-size: var(--text-sm);
		color: var(--accent-regular);
		font-weight: 600;
		margin-top: 0.25rem;
		max-width: none;
	}

	.hero-cta {
		margin-top: 1.25rem;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 1.5rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 2.5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.ai-cards {
		display: grid;
		gap: 1.25rem;
		grid-column: 1 / -1;
	}

	.ai-card {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		padding: 1.5rem;
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.ai-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.ai-card-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.ai-card h4 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin: 0;
	}

	.ai-card p {
		color: var(--gray-300);
		font-size: var(--text-sm);
		line-height: 1.6;
		margin: 0;
	}

	.ai-tag {
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		white-space: nowrap;
	}

	.ai-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.75rem;
	}

	.ai-pill {
		font-size: 0.65rem;
		padding: 0.2rem 0.55rem;
		border-radius: 999rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		white-space: nowrap;
	}

	.app-carousel-wrapper {
		grid-column: 1 / -1;
		overflow: hidden;
	}

	.app-carousel {
		display: flex;
		gap: 1.5rem;
		animation: scroll-carousel 20s linear infinite;
		width: max-content;
	}

	.app-carousel:hover {
		animation-play-state: paused;
	}

	@keyframes scroll-carousel {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}

	.app-carousel-item {
		scroll-snap-align: start;
		flex-shrink: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		transition: transform 0.2s;
	}

	.app-carousel-item:hover {
		transform: translateY(-3px);
	}

	.app-carousel-item img {
		width: 80px;
		height: 80px;
		border-radius: 1.25rem;
		border: 1px solid var(--gray-800);
		object-fit: cover;
	}

	.app-carousel-item span {
		font-size: 0.75rem;
		color: var(--gray-300);
		text-align: center;
		max-width: 88px;
		white-space: nowrap;
		overflow: hidden;
