---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Content | Francisco Cucullu"
	description="Private content dashboard"
	robots="noindex,nofollow"
>
	<main class="wrapper stack gap-8" id="content-root">
		<header class="page-head stack gap-2">
			<h1 id="page-title">Dashboard</h1>
			<p class="subtitle" id="page-subtitle" hidden>Pending social posts ready to copy &amp; publish.</p>
		</header>

		<!-- States -->
		<div id="state-loading" class="state">Loading…</div>

		<div id="state-signin" class="state" hidden>
			<button id="btn-google" class="btn-primary">Sign in with Google</button>
		</div>

		<div id="state-unauthorized" class="state" hidden>
			<p>Not authorized. This account can't view this page.</p>
			<button id="btn-signout-unauth" class="btn-secondary">Sign out</button>
		</div>

		<div id="state-dashboard" class="state" hidden>
			<div class="toolbar">
				<span id="user-email" class="user-email"></span>
				<button id="btn-signout" class="btn-secondary">Sign out</button>
			</div>

			<div id="empty-state" class="state" hidden>
				<p>No pending posts.</p>
			</div>

			<div class="table-wrap" id="table-wrap">
				<table class="content-table">
					<thead>
						<tr>
							<th class="col-platform">Platform</th>
							<th class="col-topic">Topic</th>
							<th class="col-post">Post</th>
							<th class="col-actions">Actions</th>
						</tr>
					</thead>
					<tbody id="rows"></tbody>
				</table>
			</div>
		</div>
	</main>
</BaseLayout>

<script>
	import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

	const SUPABASE_URL = 'https://ytgyumihoeiwuyxbptjj.supabase.co';
	const SUPABASE_ANON_KEY =
		'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl0Z3l1bWlob2Vpd3V5eGJwdGpqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyMTY5ODksImV4cCI6MjA4OTc5Mjk4OX0.cz4Ok0rWud--UnHQCEPB2ebIsTtwpBzA1L6PLul-IVg';
	const ALLOWED_EMAIL = 'francisco.cucullu@gmail.com';

	const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

	const $ = (id: string) => document.getElementById(id)!;

	function show(state: 'loading' | 'signin' | 'unauthorized' | 'dashboard') {
		(['loading', 'signin', 'unauthorized', 'dashboard'] as const).forEach((s) => {
			$(`state-${s}`).hidden = s !== state;
		});
	}

	function escapeHtml(s: string) {
		const d = document.createElement('div');
		d.textContent = s;
		return d.innerHTML;
	}

	type Post = {
		id: string;
		platform: 'linkedin' | 'x';
		topic: string | null;
		content: string;
		status: string;
		created_at: string;
	};

	function renderPosts(posts: Post[]) {
		$('empty-state').hidden = posts.length > 0;
		$('table-wrap').hidden = posts.length === 0;

		const rows = $('rows');
		rows.innerHTML = posts
			.map((p) => {
				const label = p.platform === 'linkedin' ? 'LinkedIn' : 'X';
				return `
				<tr data-id="${p.id}">
					<td class="col-platform"><span class="badge badge-${p.platform}">${label}</span></td>
					<td class="col-topic">${p.topic ? escapeHtml(p.topic) : ''}</td>
					<td class="col-post">
						<div class="post-full">${escapeHtml(p.content)}</div>
						<textarea class="post-edit" hidden>${escapeHtml(p.content)}</textarea>
					</td>
					<td class="col-actions">
						<button class="btn-secondary btn-copy">Copy</button>
						<button class="btn-secondary btn-edit">Edit</button>
						<button class="btn-primary btn-save" hidden>Save</button>
						<button class="btn-secondary btn-cancel" hidden>Cancel</button>
						<button class="btn-primary btn-publish">Mark published</button>
					</td>
				</tr>`;
			})
			.join('');

		rows.querySelectorAll<HTMLButtonElement>('.btn-copy').forEach((btn) => {
			btn.addEventListener('click', async () => {
				const tr = btn.closest('tr')!;
				const text = tr.querySelector('.post-full')!.textContent || '';
				try {
					await navigator.clipboard.writeText(text);
					const orig = btn.textContent;
					btn.textContent = 'Copied!';
					setTimeout(() => (btn.textContent = orig), 1500);
				} catch {
					alert('Could not copy to clipboard.');
				}
			});
		});

		function setEditMode(tr: HTMLElement, editing: boolean) {
			(tr.querySelector('.post-full') as HTMLElement).hidden = editing;
			(tr.querySelector('.post-edit') as HTMLElement).hidden = !editing;
			(tr.querySelector('.btn-edit') as HTMLElement).hidden = editing;
			(tr.querySelector('.btn-save') as HTMLElement).hidden = !editing;
			(tr.querySelector('.btn-cancel') as HTMLElement).hidden = !editing;
			(tr.querySelector('.btn-copy') as HTMLElement).hidden = editing;
			(tr.querySelector('.btn-publish') as HTMLElement).hidden = editing;
		}

		rows.querySelectorAll<HTMLButtonElement>('.btn-edit').forEach((btn) => {
			btn.addEventListener('click', () => {
				const tr = btn.closest('tr') as HTMLElement;
				const ta = tr.querySelector('.post-edit') as HTMLTextAreaElement;
				ta.value = (tr.querySelector('.post-full') as HTMLElement).textContent || '';
				setEditMode(tr, true);
				ta.style.height = 'auto';
				ta.style.height = ta.scrollHeight + 'px';
				ta.focus();
			});
		});

		rows.querySelectorAll<HTMLButtonElement>('.btn-cancel').forEach((btn) => {
			btn.addEventListener('click', () => {
				setEditMode(btn.closest('tr') as HTMLElement, false);
			});
		});

		rows.querySelectorAll<HTMLButtonElement>('.btn-save').forEach((btn) => {
			btn.addEventListener('click', async () => {
				const tr = btn.closest('tr') as HTMLElement;
				const id = tr.dataset.id!;
				const ta = tr.querySelector('.post-edit') as HTMLTextAreaElement;
				const newContent = ta.value;
				btn.disabled = true;
				btn.textContent = 'Saving…';
				const { error } = await supabase
					.from('portfolio_content_posts')
					.update({ content: newContent })
					.eq('id', id);
				btn.disabled = false;
				btn.textContent = 'Save';
				if (error) {
					alert('Error saving: ' + error.message);
					return;
				}
				(tr.querySelector('.post-full') as HTMLElement).textContent = newContent;
				setEditMode(tr, false);
			});
		});

		rows.querySelectorAll<HTMLButtonElement>('.btn-publish').forEach((btn) => {
			btn.addEventListener('click', async () => {
				const tr = btn.closest('tr') as HTMLElement;
				const id = tr.dataset.id!;
				btn.disabled = true;
				btn.textContent = 'Saving…';
				const { error } = await supabase
					.from('portfolio_content_posts')
					.update({ status: 'published', published_at: new Date().toISOString() })
					.eq('id', id);
				if (error) {
					btn.disabled = false;
					btn.textContent = 'Mark published';
					alert('Error: ' + error.message);
					return;
				}
				tr.remove();
				const remaining = $('rows').querySelectorAll('tr').length;
				$('empty-state').hidden = remaining > 0;
				$('table-wrap').hidden = remaining === 0;
			});
		});
	}

	async function loadDashboard(email: string) {
		$('page-title').textContent = 'Content';
		$('page-subtitle').hidden = false;
		$('user-email').textContent = email;
		const { data, error } = await supabase
			.from('portfolio_content_posts')
			.select('id, platform, topic, content, status, created_at')
			.neq('status', 'published')
			.order('created_at', { ascending: false });
		if (error) {
			alert('Error loading posts: ' + error.message);
			renderPosts([]);
			return;
		}
		renderPosts((data ?? []) as Post[]);
	}

	async function route() {
		const { data: { session } } = await supabase.auth.getSession();
		if (!session) {
			show('signin');
			return;
		}
		const email = session.user.email ?? '';
		if (email.toLowerCase() !== ALLOWED_EMAIL) {
			show('unauthorized');
			return;
		}
		show('dashboard');
		await loadDashboard(email);
	}

	$('btn-google').addEventListener('click', async () => {
		await supabase.auth.signInWithOAuth({
			provider: 'google',
			options: { redirectTo: window.location.origin + window.location.pathname },
		});
	});

	const signOut = async () => {
		await supabase.auth.signOut();
		show('signin');
	};
	$('btn-signout').addEventListener('click', signOut);
	$('btn-signout-unauth').addEventListener('click', signOut);

	supabase.auth.onAuthStateChange(() => {
		route();
	});

	route();
</script>

<style>
	.page-head h1 {
		margin: 0;
		font-size: var(--text-3xl);
		color: var(--gray-0);
	}
	.subtitle {
		color: var(--gray-300);
		margin: 0;
	}
	.state {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	#state-dashboard {
		gap: 1.5rem;
	}
	.toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.user-email {
		font-size: var(--text-sm);
		color: var(--gray-300);
	}

	.table-wrap {
		overflow-x: auto;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
	}
	.content-table {
		width: 100%;
		border-collapse: collapse;
		font-size: var(--text-sm);
	}
	.content-table thead th {
		text-align: left;
		padding: 0.85rem 1rem;
		background: var(--gray-999);
		color: var(--gray-200);
		font-weight: 700;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		border-bottom: 1px solid var(--gray-800);
		white-space: nowrap;
	}
	.content-table tbody td {
		padding: 1rem;
		border-bottom: 1px solid var(--gray-800);
		vertical-align: top;
	}
	.content-table tbody tr:last-child td {
		border-bottom: none;
	}
	.col-platform { width: 1%; white-space: nowrap; }
	.col-topic { width: 14%; color: var(--gray-100); font-weight: 600; }
	.col-post { width: auto; }
	.col-actions { width: 1%; white-space: nowrap; }

	.post-full {
		white-space: pre-wrap;
		line-height: 1.65;
		color: var(--gray-100);
		max-width: 70ch;
	}
	.post-edit {
		width: 100%;
		max-width: 70ch;
		min-height: 8rem;
		resize: vertical;
		padding: 0.75rem;
		border-radius: 0.5rem;
		border: 1px solid var(--accent-regular);
		background: var(--gray-999);
		color: var(--gray-0);
		font-family: var(--font-body, inherit);
		font-size: var(--text-sm);
		line-height: 1.65;
		white-space: pre-wrap;
	}

	.badge {
		font-size: 0.65rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.badge-linkedin { background: rgba(10, 102, 194, 0.18); color: #4a9eff; }
	.badge-x { background: rgba(255, 255, 255, 0.12); color: var(--gray-100); }

	.col-actions {
		display: table-cell;
	}
	.col-actions .btn-secondary,
	.col-actions .btn-primary {
		display: block;
		width: 100%;
		margin-bottom: 0.5rem;
	}
	.col-actions .btn-primary:last-child,
	.col-actions .btn-secondary:last-child {
		margin-bottom: 0;
	}

	.btn-primary,
	.btn-secondary {
		font-size: var(--text-sm);
		font-weight: 600;
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		cursor: pointer;
		transition: all 0.2s;
		border: 1px solid transparent;
		white-space: nowrap;
	}
	.btn-primary {
		background: var(--accent-regular);
		color: #fff;
	}
	.btn-primary:hover { background: var(--accent-dark); }
	.btn-primary:disabled { opacity: 0.6; cursor: default; }
	.btn-secondary {
		background: transparent;
		border-color: var(--gray-800);
		color: var(--gray-200);
	}
	.btn-secondary:hover {
		background: var(--accent-subtle-overlay);
		color: var(--gray-0);
	}
</style>
