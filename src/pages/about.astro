---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About | Francisco Cucullu" description="About Francisco Cucullu">
    <div class="stack gap-20">
        <main class="wrapper about">
            <Hero
                title="About Me"
                tagline="AI Product Leader. I build high-performing teams and scalable AI products across enterprise, fintech, and social impact."
                data-fast-scroll="scroll_to_about_start"
            >
                <img
                    width="1553"
                    height="873"
                    src="/assets/at-work.jpg"
                    alt="Francisco Cucullu pitching at South Summit"
                />
            </Hero>

            <section data-fast-scroll="scroll_to_about_education">
            <h2 class="section-title">Education</h2>
            <div class="content">
                <p>
                <strong>Dual MSc in Quantitative Finance</strong><br />
                Solvay Brussels School of Economics & Management (Belgium)<br />
                Universidad de San Andres (Argentina)
                </p>
                <div style="height: 15px;"></div>

                <p>
                <strong>BSc in Economics</strong><br />
                Universidad de Buenos Aires (Argentina)
                </p>
                <div style="height: 15px;"></div>

                <p>
                <strong>Executive Education</strong><br />
                Harvard Business School, Management & Leadership Program
                </p>
                <div style="height: 15px;"></div>

                <p>
                <a data-fast-goal="click_on_about_get_cv" href="https://drive.google.com/file/d/1uA-lgBc2c-YwcvtCeRh1Q9i2F3Ob-pr3/view?usp=sharing" target="_blank">Download full CV →</a>
                </p>
            </div>
            </section>

            <section data-fast-scroll="scroll_to_about_achievements">
            <h2 class="section-title">Key Achievements</h2>
            <div class="content">
                <p>
                <strong>AI Innovation Award</strong><br />
                Recognized for integrating AI/ML into blockchain-based wealth management. Delivered data-driven tools for financial product personalization and automation.
                <a data-fast-goal="click_on_about_innovation_award" href="https://www.corporatevision-news.com/winners/xcapit/">See full story →</a>
                </p>
                <div style="height: 20px;"></div>
                <p>
                <strong>UNICEF Digital Public Good</strong><br />
                Led a team of PhDs to build an open-source crypto wallet for financial inclusion. $650K in microloans to 330 underbanked individuals. Funded by UNICEF and Ethereum Foundation.
                <a data-fast-goal="click_on_about_tech_for_social_impact" href="https://app.digitalpublicgoods.net/a/11545">See recognition →</a>
                </p>
                <div style="height: 20px;"></div>
                <p>
                <strong>20% Market Capture via Automation</strong><br />
                Built 21 real-time scrapers (including mobile app emulators) to monitor every competitor in the Argentine FX market. Enabled a pricing strategy that captured 20% of the target market.
                <a data-fast-goal="click_on_about_automation_market_growth" href="https://github.com/fcucullu/scrapers-webdrivers">See repository →</a>
                </p>
                <div style="height: 20px;"></div>
                <p>
                <strong>Enterprise AI at Scale</strong><br />
                Leading an AI QA Suite analyzing millions of daily customer interactions for a global CX leader (130K+ employees). Multi-modal AI: audio, speech-to-text, LLMs. Driving multi-million dollar annual savings.
                </p>
            </div>
            </section>

            <section data-fast-scroll="scroll_to_about_experience">
            <h2 class="section-title">Experience</h2>
            <div class="content">
                <strong>AI Product Consultant, IAG (2024 - Present)</strong>
                <p>
                Leading AI product initiatives for enterprise clients. Currently serving as Senior AI/ML Product Manager for one of the company's flagship AI Suite products. Also leading RAID (Rapid AI Development), taking products from ideation to MVP in one week.
                </p>

                <div style="height: 20px;"></div>

                <strong>CPTO, The Pepino Brand (2023 - 2026)</strong>
                <p>
                Rebuilt a MarTech startup's Brand Asset Management platform from scratch. Led product discovery, technical architecture, investor engagement, and team leadership.
                </p>

                <div style="height: 20px;"></div>

                <strong>Co-founder & CTO, Xcapit (2019 - 2023)</strong>
                <p>
                Built an AI-powered wealth management platform. Algorithmic trading ($2M portfolio, 400%+ returns), AI portfolio management, and financial inclusion (UNICEF-backed). Led a cross-functional team of PhDs.
                </p>

                <div style="height: 20px;"></div>

                <strong>Head of Business Intelligence, Argentina's Largest Retail Broker (2017 - 2019)</strong>
                <p>
                Started as lead quantitative trader, built the <a href="https://github.com/fcucullu/trading-fx">FX arbitrage engine</a>, and transitioned the team into a BI unit. Built automation tools, dashboards, and ML models for customer segmentation.
                </p>

                <div style="height: 20px;"></div>

                <strong>Banking & Trading (2014 - 2017)</strong>
                <p>
                HSBC Bank (client relations, investment products, business performance management). Corporate broker trading desk (portfolio management, financial modeling). Built <a href="https://github.com/fcucullu/RPA">RPA automation tools</a> that freed the team for higher-value analytics.
                </p>
            </div>
            </section>

            <section data-fast-scroll="scroll_to_about_skills">
            <h2 class="section-title">Technical Skills</h2>
            <div class="content">
                <div class="container">
                <div class="column">
                    <p><strong>AI/ML</strong></p>
                    <p>LLMs, NLP, Speech-to-Text</p>
                    <p>Neural Networks, LSTM</p>
                    <p>Genetic Algorithms</p>
                    <p>Bayesian Optimization</p>
                </div>
                <div class="column">
                    <p><strong>Engineering</strong></p>
                    <p>Python, TypeScript</p>
                    <p>React, Next.js, React Native</p>
                    <p>PostgreSQL, Supabase</p>
                    <p>Docker, Kubernetes, CI/CD</p>
                </div>
                <div class="column">
                    <p><strong>Product</strong></p>
                    <p>0-to-1 product development</p>
                    <p>Cross-functional leadership</p>
                    <p>Agile, rapid prototyping</p>
                    <p>Stakeholder management</p>
                </div>
                </div>
            </div>
            </section>

        </main>

        <ContactCTA />
    </div>
</BaseLayout>
<script>
  window?.datafast("surfed-to-about");
</script>
<style>
    .about {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    img {
        margin-top: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
    }

    section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        color: var(--gray-200);
    }

    .section-title {
        grid-column-start: 1;
        font-size: var(--text-xl);
        color: var(--gray-0);
    }

    .content {
        grid-column: 2 / 4;
    }

    .content :global(a) {
        color: var(--accent-light);
        text-decoration: 1px solid underline transparent;
        text-underline-offset: 0.25em;
        transition: text-decoration-color var(--theme-transition);
    }

    .content :global(a:hover),
    .content :global(a:focus) {
        text-decoration-color: currentColor;
    }

	strong {
        font-size: 1.15rem;
        margin-bottom: 0.25rem;
        color: var(--gray-0);
    }

    @media (min-width: 50em) {
        .about {
            display: grid;
            grid-template-columns: 1fr 60% 1fr;
        }

        .about > :global(:first-child) {
            grid-column-start: 2;
        }

        section {
            display: contents;
            font-size: var(--text-lg);
        }

        .container {
            display: flex;
            justify-content: space-between;
        }

        .column {
            flex: 1;
            margin: 0 1rem;
        }
    }
</style>
