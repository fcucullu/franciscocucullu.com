---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About | Francisco Cucullu" description="About Francisco Cucullu">
    <div class="stack gap-20">
        <main class="wrapper about">
            <Hero
                title="Builder.<br/>Product Leader.<br/>AI at scale."
                tagline=""
                data-fast-scroll="scroll_to_about_start"
            >
                <img
                    width="1553"
                    height="873"
                    src="/assets/at-work.jpg"
                    alt="Francisco Cucullu pitching at South Summit"
                />
            </Hero>

            <section>
                <h2 class="section-title">Summary</h2>
                <div class="content">
                    <p>
                        Product leader, engineer, founder. Led 24 engineers at enterprise scale. Designed custom AI/ML with 5 PhDs. Built and sold a micro-SaaS to Factorial. Recognized by UNICEF. Featured on TV, South Summit, and international stages. I ship 1 MVP per week.
                    </p>
                </div>
            </section>

            <section>
                <h2 class="section-title">Career</h2>
                <div class="content">
                    <div class="role">
                        <strong>Senior AI/ML Product Manager</strong>
                        <span class="role-meta">Foundever (via IAG) | 2024 - Present</span>
                        <p>Leading a flagship AI Suite for a global CX leader (130K+ employees). 20K+ active users, 9M+ daily interactions. 4 squads, 24 engineers. Multi-modal AI: audio, speech-to-text, LLMs. Driving multi-million dollar annual savings. <a href="/blog/ai-quality-assurance">Read more</a></p>
                    </div>

                    <div class="role">
                        <strong>CPTO & Co-founder</strong>
                        <span class="role-meta">The Pepino Brand | 2025 - 2026</span>
                        <p>Co-founded a B2B SaaS for digital asset management. Rebuilt product from scratch. Closed 7 agencies including Credo and BBK Foundation. Team of 3. <a href="/blog/pepino-brand">Read more</a></p>
                    </div>

                    <div class="role">
                        <strong>Founder (Micro-SaaS, sold to Factorial)</strong>
                        <span class="role-meta">Timed Integrations | 2024</span>
                        <p>Built ERP integrations for Factorial's Italian market. Automated time tracking data ingestion. Solo founder, built and sold. <a href="/blog/timed-integrations">Read more</a></p>
                    </div>

                    <div class="role">
                        <strong>Tech Product Manager</strong>
                        <span class="role-meta">Hastee (HR/Fintech) | 2023 - 2024</span>
                        <p>Increased engineering output 137%. Led 13 engineers across 3 teams. Integrated with multiple EU ERP systems. Aligned roadmap with C-level objectives. <a href="/blog/hastee">Read more</a></p>
                    </div>

                    <div class="role">
                        <strong>Founder & Product Lead</strong>
                        <span class="role-meta">FlexRent | 2023</span>
                        <p>Room exchange platform for digital nomads. 620 community members, 32 paying customers. Pitched at South Summit, Warsaw, DES Malaga. Featured on TV. Angel investment secured. Team of up to 9. <a href="/blog/flexrent">Read more</a></p>
                    </div>

                    <div class="role">
                        <strong>Engineering Manager</strong>
                        <span class="role-meta">Xcapit (AI + Blockchain) | 2019 - 2023</span>
                        <p>AI-powered wealth management. $2M portfolio, 400%+ annual returns. $650K in microloans to 330 people. Team of 5 PhDs. Funded by <a href="https://app.digitalpublicgoods.net/a/11545">UNICEF</a> and Ethereum Foundation. <a href="https://www.corporatevision-news.com/winners/xcapit/">AI Innovation Award</a>. Featured in <a href="https://www.cronista.com/infotechnology/finanzas-digitales/la-unica-inversion-que-hoy-paga-400-en-dolares-sin-riesgo-argentino-ni-impuestos/">Cronista</a> and <a href="https://www.criptonoticias.com/comunidad/ceo-xcapit-defi-democraticas-porque-barreras-mas-bajas/">CriptoNoticias</a>.</p>
                    </div>

                    <div class="role">
                        <strong>Quant Trader → Head of Business Intelligence</strong>
                        <span class="role-meta">IOL (Argentina's largest retail broker) | 2017 - 2019</span>
                        <p>Built <a href="/blog/fx-arbitrage">FX arbitrage engine</a> capturing ~20% market share. <a href="/blog/competitive-intelligence">21 scrapers</a> monitoring every competitor. Cut churn 32% via ML segmentation. Onboarding 72h → 24h. Led team of 4. <a href="/blog/rpa-trading-desk">Automated 5h/day</a> of manual work.</p>
                    </div>

                    <div class="role">
                        <strong>Banking Foundations</strong>
                        <span class="role-meta">HSBC Bank | Earlier career</span>
                        <p>Client relations specialist managing high-end investment products. Business Performance Management team. Built <a href="/blog/rpa-trading-desk">RPA automation tools</a>. Foundation for data, technology, and product leadership.</p>
                    </div>
                </div>
            </section>

            <section>
                <h2 class="section-title">Key Achievements</h2>
                <div class="content">
                    <p><strong>AI Innovation Award</strong><br />Recognized for integrating AI/ML into blockchain wealth management. <a href="https://www.corporatevision-news.com/winners/xcapit/">See full story</a></p>
                    <div class="spacer"></div>

                    <p><strong>UNICEF Digital Public Good</strong><br />Led a team of 5 PhDs to build an open-source crypto wallet for financial inclusion. $650K in microloans to 330 people. <a href="https://app.digitalpublicgoods.net/a/11545">See recognition</a></p>
                    <div class="spacer"></div>

                    <p><strong>Micro-SaaS Acquired by Factorial</strong><br />Built ERP integrations for the Italian market. Solo founder, built and sold. <a href="/blog/timed-integrations">Read the story</a></p>
                    <div class="spacer"></div>

                    <p><strong>400%+ Annual Returns</strong><br />Algorithmic trading on a $2M portfolio using custom ML and Bayesian optimization. Featured in <a href="https://www.cronista.com/infotechnology/finanzas-digitales/la-unica-inversion-que-hoy-paga-400-en-dolares-sin-riesgo-argentino-ni-impuestos/">Cronista</a></p>
                    <div class="spacer"></div>

                    <p><strong>20% Market Capture via Automation</strong><br />Built 21 real-time scrapers monitoring every competitor in the Argentine FX market. <a href="https://github.com/fcucullu/scrapers-webdrivers">See repository</a></p>
                    <div class="spacer"></div>

                    <p><strong>Featured on TV and International Stages</strong><br />Television interview on 101 TV, pitches at South Summit, Warsaw, and DES Malaga. <a href="/blog/speaking-tv-interview">Watch</a></p>
                    <div class="spacer"></div>

                    <p><strong>Enterprise AI at Scale</strong><br />Leading an AI product serving 20K+ users, processing 9M+ daily interactions for a global CX leader with 130K+ employees. <a href="/blog/ai-quality-assurance">Read more</a></p>
                </div>
            </section>

            <section>
                <h2 class="section-title">Education</h2>
                <div class="content">
                    <p>
                        <strong>Dual MSc in Quantitative Finance</strong><br />
                        Solvay Brussels School of Economics & Management (Belgium)<br />
                        Universidad de San Andres (Argentina)
                    </p>
                    <div class="spacer-sm"></div>
                    <p>
                        <strong>BSc in Economics</strong><br />
                        Universidad de Buenos Aires (Argentina)
                    </p>
                    <div class="spacer-sm"></div>
                    <p>
                        <strong>Executive Education</strong><br />
                        Harvard Business School, Management & Leadership Program
                    </p>
                    <div class="spacer-sm"></div>
                    <p>
                        <strong>CFA Level I</strong><br />
                        CFA Institute
                    </p>
                </div>
            </section>

        </main>

        <ContactCTA />
    </div>
</BaseLayout>
<script>
  window?.datafast("surfed-to-about");
</script>
<style>
    .about {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    img {
        margin-top: 1.5rem;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
    }

    section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        color: var(--gray-200);
    }

    .section-title {
        grid-column-start: 1;
        font-size: var(--text-xl);
        color: var(--gray-0);
    }

    .content {
        grid-column: 2 / 4;
    }

    .content :global(a) {
        color: #a855f7;
        text-decoration: 1px solid underline transparent;
        text-underline-offset: 0.25em;
        transition: text-decoration-color var(--theme-transition);
    }

    .content :global(a:hover),
    .content :global(a:focus) {
        text-decoration-color: currentColor;
    }

    strong {
        font-size: 1.15rem;
        margin-bottom: 0.25rem;
        color: var(--gray-0);
    }

    .role {
        margin-bottom: 1.5rem;
    }

    .role strong {
        display: block;
        font-size: 1.1rem;
    }

    .role-meta {
        display: block;
        font-size: 0.85rem;
        color: var(--gray-400);
        margin-bottom: 0.4rem;
    }

    .role p {
        margin: 0;
        line-height: 1.6;
    }

    .spacer {
        height: 16px;
    }

    .spacer-sm {
        height: 12px;
    }

    @media (min-width: 50em) {
        .about {
            display: grid;
            grid-template-columns: 1fr 60% 1fr;
        }

        .about > :global(:first-child) {
            grid-column-start: 2;
        }

        section {
            display: contents;
            font-size: var(--text-lg);
        }
    }
</style>
