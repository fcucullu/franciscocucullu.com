---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const articles = [
	{
		title: "The WASP Framework: From Challenge to AI MVP in One Week",
		description: "A hypothesis-driven methodology for building AI products at enterprise speed. Three phases: Challenge Scoping, Problem Space, Solution Space.",
		href: "/blog/wasp-framework",
		tag: "AI Product Management",
		date: "May 2026",
	},
	{
		title: "Scaling QA with AI: From 2% to 100% Coverage",
		description: "How a telecom operator transformed QA operations with AI calibration at scale, achieving 82% accuracy while analyzing every customer interaction.",
		href: "/blog/ai-quality-assurance",
		tag: "AI Quality Assurance",
		date: "December 2024",
	},
	{
		title: "Building an FX Arbitrage Engine: How I Automated a Trading Desk",
		description: "Multi-threaded Python system that exploited FX pricing inefficiencies at Argentina's largest broker. Led to promotion to Head of BI.",
		href: "/blog/fx-arbitrage",
		tag: "Algorithmic Trading",
		date: "2019",
	},
	{
		title: "21 Scrapers, 20% Market Share: Building a Competitive Intelligence Engine",
		description: "How I built 21 real-time scrapers (including mobile app emulators) to monitor every competitor in the Argentine FX market.",
		href: "/blog/competitive-intelligence",
		tag: "Data Engineering",
		date: "2017",
	},
	{
		title: "From 5 Hours to Zero: Automating a Trading Desk's Post-Market Operations",
		description: "Python-based automation that eliminated 5+ hours of daily manual work for a 5-person team. The evolution from VBA to full ETL pipelines.",
		href: "/blog/rpa-trading-desk",
		tag: "Automation",
		date: "2016",
	},
	{
		title: "Building AI Before ChatGPT: Custom ML at a UNICEF-Backed Fintech",
		description: "Neural networks, genetic algorithms, and Bayesian optimization built from scratch with a team of 5 PhDs. Before the LLM revolution.",
		href: "/blog/custom-ai-ml",
		tag: "AI/ML",
		date: "2020",
	},
	{
		title: "400% Returns: How Bayesian Optimization Tuned Our Trading Strategies",
		description: "Gaussian Process-based hyperparameter optimization for algorithmic trading. Featured in Cronista and CriptoNoticias.",
		href: "/blog/bayesian-optimization",
		tag: "Quantitative Finance",
		date: "2020",
	},
	{
		title: "Zero Integration Bugs: How I Built an API Contract Platform for My Teams",
		description: "Auto-generated test cases from API schemas. Frontend and backend agree on contracts from day zero.",
		href: "/blog/api-contract-hub",
		tag: "Engineering Leadership",
		date: "2025",
	},
	{
		title: "Reducing Data Requests to Zero: Building a Self-Serve Analytics Bot",
		description: "Discord bot that democratized data access across the company. Eliminated 100% of ad-hoc data requests.",
		href: "/blog/discord-data-bot",
		tag: "Data Engineering",
		date: "2020",
	},
	{
		title: "Featured on TV: Discussing Tech Innovation on Hola Andalucia",
		description: "Television appearance on 101 TV Malaga's tech segment.",
		href: "/blog/speaking-tv-interview",
		tag: "Media",
		date: "2023",
	},
	{
		title: "On Stage at South Summit: Europe's Leading Startup Conference",
		description: "Main stage pitch at South Summit, one of Europe's top startup conferences.",
		href: "/blog/speaking-south-summit",
		tag: "Pitch",
		date: "2023",
	},
	{
		title: "Pitching at Warsaw Startup Stage",
		description: "International startup pitch competition in Warsaw, Poland.",
		href: "/blog/speaking-warsaw",
		tag: "Pitch",
		date: "2023",
	},
	{
		title: "DES Malaga: Pitching to Investors at the Digital Enterprise Show",
		description: "Pitched FlexRent at one of Europe's largest digital transformation events.",
		href: "/blog/speaking-des-malaga",
		tag: "Pitch",
		date: "2023",
	},
	{
		title: "AI AutoQA at the Coach Summit: Presenting to 80+ Enterprise Leaders",
		description: "Presented AI AutoQA at enterprise summits in Barcelona and Seville.",
		href: "/blog/speaking-coach-summit",
		tag: "Enterprise AI",
		date: "2025",
	},
	{
		title: "Video Interview: Product Vision and Startup Execution",
		description: "In-depth interview on product vision, market strategy, and startup execution.",
		href: "/blog/speaking-video-interview",
		tag: "Interview",
		date: "2023",
	},
	{
		title: "Radio Interview: Technology and Entrepreneurship",
		description: "Radio interview discussing technology, entrepreneurship, and innovation.",
		href: "/blog/speaking-radio-interview",
		tag: "Interview",
		date: "2023",
	},
	{
		title: "Dealing with Heteroscedasticity",
		description: "Technical article on statistical modeling and handling non-constant variance in financial data.",
		href: "https://www.linkedin.com/pulse/dealing-heterocedaticity-francisco-cucullu",
		tag: "Quantitative Finance",
		date: "2019",
		external: true,
	},
];
---

<BaseLayout
	title="Blog | Francisco Cucullu"
	description="Articles on AI product management, quantitative finance, and technology"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Blog"
				tagline="Thoughts on AI product management, quantitative finance, and building at scale."
				align="center"
			/>

			<div class="articles-grid">
				{articles.map((article) => (
					<a href={article.href} target={article.external ? "_blank" : undefined} rel={article.external ? "noopener" : undefined} class="article-card">
						<div class="article-tag-row">
							<span class="article-tag">{article.tag}</span>
							{article.external && <span class="external-badge">External</span>}
						</div>
						<h3>{article.title}</h3>
						<p>{article.description}</p>
						<span class="article-date">{article.date}</span>
					</a>
				))}
			</div>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.articles-grid {
		display: grid;
		gap: 1.5rem;
	}

	.article-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		text-decoration: none;
		color: var(--gray-200);
		transition: box-shadow 0.2s, transform 0.2s;
	}

	.article-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.article-tag-row {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.article-tag {
		font-size: 0.7rem;
		padding: 0.2rem 0.6rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		white-space: nowrap;
	}

	.external-badge {
		font-size: 0.65rem;
		padding: 0.15rem 0.5rem;
		border-radius: 999rem;
		font-weight: 600;
		border: 1px solid var(--gray-800);
		color: var(--gray-400);
	}

	.article-card h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin: 0;
	}

	.article-card p {
		font-size: var(--text-sm);
		color: var(--gray-300);
		margin: 0;
		line-height: 1.6;
	}

	.article-date {
		font-size: 0.75rem;
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.articles-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
