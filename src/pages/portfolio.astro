---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const apps = (await getCollection('apps'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
	title="Portfolio | Francisco Cucullu"
	description="Projects and apps built by Francisco Cucullu"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Portfolio"
				tagline="Professional projects and personal apps. All designed, built, and shipped."
				align="center"
			/>

			<section>
				<h2 class="section-title">Professional Work</h2>
				<div class="gallery">
					<Grid variant="offset">
						{projects.map((project) => (
							<li>
								<PortfolioPreview project={project} />
							</li>
						))}
					</Grid>
				</div>
			</section>

			<section>
				<h2 class="section-title">Apps I Ship</h2>
				<p class="section-subtitle">Built solo, from idea to production in days. Native Android apps on Google Play, PWAs, SaaS platforms.</p>
				<div class="apps-grid">
					{apps.map((app) => (
						<div class="app-card">
							<img src={app.data.img} alt={app.data.img_alt || ''} loading="lazy" class="app-icon" />
							<div class="app-info">
								<div class="app-header">
									<h3>{app.data.title}</h3>
									<span class:list={['status', app.data.status]}>{app.data.status}</span>
								</div>
								<p class="app-desc">{app.data.description}</p>
							</div>
							<div class="app-links">
								{app.data.playStoreUrl && (
									<a href={app.data.playStoreUrl} target="_blank" rel="noopener" class="store-badge">
										<img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" />
									</a>
								)}
								<a href={app.data.url} target="_blank" rel="noopener" class="web-link">
									Open Web App →
								</a>
							</div>
						</div>
					))}
				</div>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.section-title {
		font-size: var(--text-2xl);
		color: var(--gray-0);
		margin-bottom: 1rem;
		text-align: center;
	}

	.section-subtitle {
		color: var(--gray-300);
		text-align: center;
		margin-bottom: 1.5rem;
		font-size: var(--text-md);
	}

	.gallery {
		margin-bottom: 3rem;
	}

	/* Apps grid - same as /apps page */
	.apps-grid {
		display: grid;
		gap: 1.5rem;
	}

	.app-card {
		display: grid;
		grid-template-columns: 64px 1fr auto;
		gap: 1rem;
		padding: 1.25rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		color: var(--gray-200);
		align-items: center;
	}

	.app-icon {
		width: 64px;
		height: 64px;
		object-fit: cover;
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
	}

	.app-info {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}

	.app-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.app-header h3 {
		font-size: var(--text-lg);
		margin: 0;
		color: var(--gray-0);
	}

	.status {
		font-size: 0.65rem;
		padding: 0.15rem 0.5rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		flex-shrink: 0;
	}

	.status.live { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

	.app-desc {
		font-size: var(--text-sm);
		color: var(--gray-300);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.app-links {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.store-badge img { height: 40px; width: auto; }

	.web-link {
		font-size: var(--text-sm);
		color: var(--accent-light);
		text-decoration: underline;
		text-underline-offset: 0.2em;
		white-space: nowrap;
	}

	@media (max-width: 49.99em) {
		.app-card {
			grid-template-columns: 56px 1fr;
			grid-template-rows: auto auto;
		}
		.app-links {
			grid-column: 1 / -1;
			flex-direction: row;
			justify-content: center;
			gap: 0.75rem;
		}
	}

	@media (min-width: 50em) {
		.app-card {
			grid-template-columns: 80px 1fr auto;
			gap: 1.25rem;
			padding: 1.5rem;
		}
		.app-icon { width: 80px; height: 80px; }
		.section-title { font-size: var(--text-4xl); }
	}
</style>
