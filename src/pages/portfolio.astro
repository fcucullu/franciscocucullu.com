---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const appsByDate = (await getCollection('apps'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
// Pin Clientísima first, then the rest by date.
const apps = [
	...appsByDate.filter((a) => a.data.title === 'Clientísima'),
	...appsByDate.filter((a) => a.data.title !== 'Clientísima'),
];
// Filter chips (AI last so it can render as the highlighted one).
const CATEGORIES = ['B2B SaaS', 'B2B', 'PWA', 'Native App', 'Consumer', 'AI'];
---

<BaseLayout
	title="Portfolio | Francisco Cucullu"
	description="Projects and apps built by Francisco Cucullu"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title=""
				tagline="A sample of what I've built. For clients, for companies, and for myself. All hands-on."
				align="center"
			/>

			<div class="tabs">
				<button class="tab active" data-tab="work">Professional Work</button>
				<button class="tab" data-tab="apps">Apps</button>
			</div>

			<section id="tab-apps" class="tab-content">
				<div class="filters">
					<button class="filter active" data-filter="all">All</button>
					{CATEGORIES.map((cat) => (
						<button class:list={['filter', { 'filter-ai': cat === 'AI' }]} data-filter={cat}>{cat}</button>
					))}
				</div>
				<div class="apps-grid">
					{apps.map((app) => (
						<div class="app-card" data-categories={(app.data.categories || []).join('|')}>
							<img src={app.data.img} alt={app.data.img_alt || ''} loading="lazy" class="app-icon" />
							<div class="app-info">
								<div class="app-header">
									<h3>{app.data.title}</h3>
									<span class:list={['status', app.data.status]}>{app.data.status}</span>
								</div>
								{(app.data.categories || []).length > 0 && (
									<div class="cat-badges">
										{(app.data.categories || []).map((cat) => (
											<span class:list={['cat-badge', { 'cat-badge-ai': cat === 'AI' }]}>{cat}</span>
										))}
									</div>
								)}
								<p class="app-desc">{app.data.description}</p>
							</div>
							<div class="app-links">
								{app.data.playStoreUrl && (
									<a href={app.data.playStoreUrl} target="_blank" rel="noopener" class="store-badge">
										<img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" />
									</a>
								)}
								<a href={app.data.url} target="_blank" rel="noopener" class="web-link">
									Open Web App →
								</a>
							</div>
						</div>
					))}
				</div>
			</section>

			<section id="tab-work" class="tab-content active">
				<div class="gallery">
					<Grid variant="offset">
						{projects.map((project) => (
							<li>
								<PortfolioPreview project={project} />
							</li>
						))}
					</Grid>
				</div>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<script>
	function activateTab(name: string) {
		document.querySelectorAll('.tab').forEach((t) => t.classList.remove('active'));
		document.querySelectorAll('.tab-content').forEach((c) => c.classList.remove('active'));
		const tab = document.querySelector(`.tab[data-tab="${name}"]`);
		tab?.classList.add('active');
		document.getElementById(`tab-${name}`)?.classList.add('active');
	}

	document.querySelectorAll('.tab').forEach((tab) => {
		tab.addEventListener('click', () => {
			const target = (tab as HTMLElement).dataset.tab!;
			activateTab(target);
			history.replaceState(null, '', `#${target}`);
		});
	});

	// Activate tab from URL hash
	const hash = window.location.hash.replace('#', '');
	if (hash === 'work' || hash === 'apps') {
		activateTab(hash);
	}

	// Apps category filter
	const filters = document.querySelectorAll('.filter');
	const cards = document.querySelectorAll<HTMLElement>('.app-card');
	filters.forEach((btn) => {
		btn.addEventListener('click', () => {
			const f = (btn as HTMLElement).dataset.filter!;
			filters.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');
			cards.forEach((card) => {
				const cats = (card.dataset.categories || '').split('|');
				card.style.display = f === 'all' || cats.includes(f) ? '' : 'none';
			});
		});
	});
</script>

<style>
	.tabs {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
	}

	.tab {
		padding: 0.6rem 1.5rem;
		border-radius: 999rem;
		border: 1px solid var(--gray-800);
		background: transparent;
		color: var(--gray-300);
		font-size: var(--text-md);
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s;
	}

	.tab:hover {
		background-color: var(--accent-subtle-overlay);
		color: var(--gray-100);
		border-color: transparent;
	}

	.tab.active {
		background: var(--accent-regular);
		color: var(--accent-text-over);
		border-color: var(--accent-regular);
	}

	.tab-content {
		display: none;
	}

	.tab-content.active {
		display: block;
	}

	/* Category filters */
	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		justify-content: center;
		margin-bottom: 1.5rem;
	}
	.filter {
		padding: 0.4rem 0.9rem;
		border-radius: 999rem;
		border: 1px solid var(--gray-800);
		background: transparent;
		color: var(--gray-300);
		font-size: var(--text-sm);
		font-weight: 600;
		cursor: pointer;
		transition: all 0.15s;
	}
	.filter:hover { color: var(--gray-100); border-color: var(--gray-600); }
	.filter.active { background: var(--accent-regular); color: var(--accent-text-over); border-color: var(--accent-regular); }
	.filter-ai {
		background: var(--gradient-accent-orange, linear-gradient(135deg, #f5a623, #f76b1c));
		color: #fff;
		border-color: transparent;
	}
	.filter-ai.active { box-shadow: 0 0 0 2px var(--gray-0); }

	/* Category badges on cards */
	.cat-badges { display: flex; flex-wrap: wrap; gap: 0.3rem; }
	.cat-badge {
		font-size: 0.6rem;
		padding: 0.12rem 0.45rem;
		border-radius: 999rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--gray-800);
		color: var(--gray-200);
	}
	.cat-badge-ai {
		background: var(--gradient-accent-orange, linear-gradient(135deg, #f5a623, #f76b1c));
		color: #fff;
	}

	/* Apps grid */
	.apps-grid {
		display: grid;
		gap: 1.5rem;
	}

	.app-card {
		display: grid;
		grid-template-columns: 64px 1fr auto;
		gap: 1rem;
		padding: 1.25rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		color: var(--gray-200);
		align-items: center;
	}

	.app-icon {
		width: 64px;
		height: 64px;
		object-fit: cover;
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
	}

	.app-info {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}

	.app-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.app-header h3 {
		font-size: var(--text-lg);
		margin: 0;
		color: var(--gray-0);
	}

	.status {
		font-size: 0.65rem;
		padding: 0.15rem 0.5rem;
		border-radius: 999rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		flex-shrink: 0;
	}

	.status.live { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
	.status.beta { background: rgba(234, 179, 8, 0.15); color: #eab308; }
	.status.offline { background: rgba(239, 68, 68, 0.15); color: #ef4444; }

	.app-desc {
		font-size: var(--text-sm);
		color: var(--gray-300);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.app-links {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.store-badge img { height: 40px; width: auto; }

	.web-link {
		font-size: var(--text-sm, 0.875rem);
		color: #fff;
		background: var(--accent-regular);
		text-decoration: none;
		white-space: nowrap;
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		font-weight: 600;
		transition: background 0.2s;
	}

	.web-link:hover {
		background: var(--accent-dark);
	}

	@media (max-width: 49.99em) {
		.app-card {
			grid-template-columns: 56px 1fr;
			grid-template-rows: auto auto;
		}
		.app-links {
			grid-column: 1 / -1;
			flex-direction: row;
			justify-content: center;
			gap: 0.75rem;
		}
	}

	@media (min-width: 50em) {
		.app-card {
			grid-template-columns: 80px 1fr auto;
			gap: 1.25rem;
			padding: 1.5rem;
		}
		.app-icon { width: 80px; height: 80px; }
	}
</style>
